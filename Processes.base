filters:
  and:
    - categories == ["[[Processes]]"]
views:
  - type: table
    name: Table
    order:
      - file.name
      - created
      - tags
      - source
    columnSize:
      file.name: 255
  - type: table
    name: Chatgpt responses
    filters:
      and:
        - source == "chatgpt-manual"
    order:
      - file.name
      - categories
      - created
      - source
    sort:
      - property: created
        direction: DESC
